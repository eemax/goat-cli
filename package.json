{
  "name": "goat-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Session-first non-interactive agent harness CLI",
  "bin": {
    "goat": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "openai": "^6.6.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^24.7.2",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
